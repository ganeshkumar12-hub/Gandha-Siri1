<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌱 Register New Tree"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/wood"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Every tree gets a unique legal Tree ID"
            android:textSize="13sp"
            android:textColor="@color/wood_light"
            android:paddingBottom="16dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- 1. PHOTO -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📸 Tree Photo"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/wood"
                    android:paddingBottom="6dp" />

                <ImageView
                    android:id="@+id/imgTreePreview"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:scaleType="centerCrop"
                    android:background="@color/sand_light"
                    android:contentDescription="Tree photo preview" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Photo will appear here after capture"
                    android:textSize="11sp"
                    android:textColor="@color/wood_light"
                    android:gravity="center"
                    android:paddingTop="4dp" />

                <Button
                    android:id="@+id/btnTakePhoto"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="📷 Take Photo of Tree"
                    android:backgroundTint="@color/sand_dark"
                    android:textColor="@color/white"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="20dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/sand_light"
                    android:layout_marginBottom="16dp" />

                <!-- 2. GPS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 GPS Location"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/wood"
                    android:paddingBottom="6dp" />

                <TextView
                    android:id="@+id/tvGpsCoords"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📡 Tap button to get location..."
                    android:textColor="@color/green_forest"
                    android:background="@color/sand_light"
                    android:padding="12dp"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btnGetLocation"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="🔄 Get My GPS Location"
                    android:backgroundTint="@color/sand"
                    android:textColor="@color/wood"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="20dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/sand_light"
                    android:layout_marginBottom="16dp" />

                <!-- 3. GIRTH -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📏 Girth (cm)"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/wood"
                    android:paddingBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Measure around the trunk with a tape"
                    android:textSize="11sp"
                    android:textColor="@color/wood_light"
                    android:paddingBottom="6dp" />

                <EditText
                    android:id="@+id/etGirth"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:hint="e.g. 45"
                    android:padding="12dp"
                    android:background="@color/white"
                    android:layout_marginBottom="20dp" />

                <!-- 4. AGE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅 Estimated Age (years)"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/wood"
                    android:paddingBottom="6dp" />

                <EditText
                    android:id="@+id/etAge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:hint="e.g. 8"
                    android:padding="12dp"
                    android:background="@color/white"
                    android:layout_marginBottom="20dp" />

                <!-- 5. NOTES -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📝 Notes"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/wood"
                    android:paddingBottom="6dp" />

                <EditText
                    android:id="@+id/etNotes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. Near north fence, healthy"
                    android:padding="12dp"
                    android:background="@color/white"
                    android:layout_marginBottom="24dp" />

                <!-- 6. REGISTER BUTTON -->
                <Button
                    android:id="@+id/btnRegisterTree"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="🌿 Register Tree and Generate ID"
                    android:backgroundTint="@color/wood"
                    android:textColor="@color/sand_light"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>